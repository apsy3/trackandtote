---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("blog", ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { slug: note.slug },
  }));
}

const { slug } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=/notes/${slug}/`} />
    <title>Redirecting to Notes</title>
    <link rel="canonical" href={`/notes/${slug}/`} />
  </head>
  <body>
    <p>
      Redirecting to <a href={`/notes/${slug}/`}>Note</a>…
    </p>
  </body>
</html>
