---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const methodItems = [
  {
    title: "Source-aware",
    detail: "Trace the source before trusting the signal.",
  },
  {
    title: "Time-aware",
    detail: "Keep observation and retrieval dates visible.",
  },
  {
    title: "Mock-first",
    detail: "Prototype structure before connecting live data.",
  },
  {
    title: "Careful claims",
    detail: "Do not describe data as complete or live without support.",
  },
] as const;
---

<BaseLayout
  title="Track & Tote"
  description="Public writing and early data experiments around society, sustainability, reporting and decision-making."
>
  <main>
    <section class="home-hero">
      <div class="home-hero-copy">
        <p class="kicker">Public notes and data experiments</p>
        <h1>Careful notes for complex systems.</h1>
        <p class="home-hero-subtitle">
          Public writing and early data experiments around society, sustainability, reporting and
          decision-making.
        </p>
        <p class="home-hero-line">
          Track &amp; Tote is a working space for essays, method notes and small public-data
          prototypes &mdash; built slowly, with source discipline and careful language.
        </p>
        <div class="hero-actions">
          <a class="button button--primary" href="/notes">Read notes</a>
          <a class="button button--quiet" href="/projects">View projects</a>
        </div>
      </div>
      <figure class="home-hero-media">
        <img
          src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1500&q=82"
          alt="Printed reports, notebooks, and research material arranged for review"
          loading="eager"
        />
      </figure>
    </section>

    <section class="section-block section-block--feature">
      <article class="feature-block">
        <div class="section-head">
          <p class="kicker">Current work</p>
          <h2>India ESG/OHSE Public Data Project</h2>
        </div>
        <div class="feature-block__body">
          <p class="status-label">Mock-data prototype</p>
          <p>
            An early-stage project exploring how public datasets can support sustainability, safety
            and reporting context over time.
          </p>
          <a class="button button--quiet" href="/projects/india-esg-ohse">View project</a>
        </div>
      </article>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Notes</p>
        <h2>Recent notes</h2>
        <p class="section-copy">
          Essays and working notes across society, public data, sustainability, technology,
          reporting and decision-making.
        </p>
      </div>
      <div class="notes-grid">
        {
          notes.map((note) => (
            <article class="note-card">
              <h3>
                <a href={`/notes/${note.slug}/`}>{note.data.title}</a>
              </h3>
              <p>{note.data.description}</p>
              <div class="note-meta">
                <time datetime={note.data.date.toISOString()}>
                  {note.data.date.toLocaleDateString("en-IN", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit",
                  })}
                </time>
              </div>
            </article>
          ))
        }
      </div>
      <p class="subtle-link">
        <a href="/notes">Browse all notes</a>
      </p>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Method strip</p>
        <h2>How we keep the work disciplined</h2>
      </div>
      <div class="method-strip">
        {
          methodItems.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
