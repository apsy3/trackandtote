---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialStatement from "@/components/home/EditorialStatement.astro";
import EditorialNotesIndex from "@/components/home/EditorialNotesIndex.astro";
import FeaturedProject from "@/components/home/FeaturedProject.astro";
import HeroSplit from "@/components/home/HeroSplit.astro";
import MethodManifesto from "@/components/home/MethodManifesto.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const methodItems = [
  {
    title: "Trace the source.",
    detail: "Start with provenance before interpretation.",
  },
  {
    title: "Keep time visible.",
    detail: "Show observation and retrieval dates.",
  },
  {
    title: "Prototype before claiming.",
    detail: "Test the shape before live connectors.",
  },
  {
    title: "Use careful language.",
    detail: "Let the evidence set the strength of the claim.",
  },
] as const;
---

<BaseLayout
  title="Track & Tote"
  description="Public writing and early data experiments around society, sustainability, reporting and decision-making."
>
  <main class="home-page">
    <HeroSplit />
    <EditorialStatement />
    <FeaturedProject />
    <EditorialNotesIndex notes={notes} />
    <MethodManifesto items={methodItems} />
  </main>
</BaseLayout>
