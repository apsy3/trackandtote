---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const methodItems = [
  {
    title: "Source-first",
    detail: "Each claim starts from a traceable source, not a visual trend alone.",
  },
  {
    title: "Time-stamped",
    detail: "Every dataset carries latest observation and retrieved-at context.",
  },
  {
    title: "Mock until verified",
    detail: "We prototype with mock data before connecting live public connectors.",
  },
  {
    title: "No false real-time claims",
    detail: "Update frequency is explicit so annual data is never framed as live.",
  },
] as const;
---

<BaseLayout
  title="Track & Tote"
  description="Public notes, data experiments, and practical methods for sustainability, reporting, and decision-making."
>
  <main>
    <section class="article-hero article-hero--home">
      <p class="kicker">Public writing and projects</p>
      <h1>Track &amp; Tote</h1>
      <p>
        Public notes, data experiments, and practical methods for sustainability, reporting, and
        decision-making.
      </p>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Featured project</p>
        <h2>India ESG/OHSE Public Data Project</h2>
      </div>
      <article class="feature-card">
        <p>
          An open, evolving experiment to connect public ESG, GHG, OHSE and sustainability
          datasets over time.
        </p>
        <a class="button" href="/projects/india-esg-ohse">View project</a>
      </article>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Latest notes</p>
        <h2>Recent writing</h2>
      </div>
      <div class="notes-grid">
        {
          notes.map((note) => (
            <article class="note-card">
              <h3>
                <a href={`/notes/${note.slug}/`}>{note.data.title}</a>
              </h3>
              <p>{note.data.description}</p>
              <div class="note-meta">
                <time datetime={note.data.date.toISOString()}>
                  {note.data.date.toLocaleDateString("en-IN", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit",
                  })}
                </time>
              </div>
            </article>
          ))
        }
      </div>
      <p class="subtle-link">
        <a href="/notes">Browse all notes</a>
      </p>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Method strip</p>
        <h2>How we keep the work disciplined</h2>
      </div>
      <div class="method-strip">
        {
          methodItems.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
