---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ChartSectionCard from "@/components/charts/ChartSectionCard";
import DataFreshnessTable from "@/components/charts/DataFreshnessTable";

const chartSections = {
  emissionsAndGrid: [
    {
      title: "India total GHG emissions trend",
      endpoint: "/api/ghg-emissions.json",
      variant: "line",
    },
    {
      title: "India power-sector grid CO2 factor trend",
      endpoint: "/api/grid-factor.json",
      variant: "bar",
    },
    {
      title: "India monthly emissions context",
      endpoint: "/api/monthly-emissions.json",
      variant: "line",
    },
  ],
  airAndClimate: [
    {
      title: "Delhi PM2.5 air quality trend",
      endpoint: "/api/air-quality-pm25.json",
      variant: "multi",
    },
    {
      title: "Delhi NO2 air quality trend",
      endpoint: "/api/air-quality-no2.json",
      variant: "multi",
    },
    {
      title: "Delhi temperature and heat trend",
      endpoint: "/api/weather-temperature.json",
      variant: "line",
    },
    {
      title: "Delhi rainfall trend",
      endpoint: "/api/weather-rainfall.json",
      variant: "bar",
    },
  ],
  riskAndSocial: [
    {
      title: "India water stress risk",
      endpoint: "/api/water-risk.json",
      variant: "line",
    },
    {
      title: "India OHSE benchmark trend",
      endpoint: "/api/ohse.json",
      variant: "line",
    },
    {
      title: "India ESG/SDG country indicator trend",
      endpoint: "/api/worldbank.json?metric=indicator",
      variant: "line",
    },
  ],
} as const;

const howToReadPoints = [
  "Begin with frequency. An annual line should not be interpreted as day-to-day volatility.",
  "Check lag before storytelling. Emissions, air quality, climate, and social indicators often move on different clocks.",
  "Treat confidence labels as discipline, not decoration. Low confidence means compare carefully and avoid strong claims.",
  "Use this page as a research notebook. It is a mock-data foundation for transparent public-data workflows.",
] as const;
---

<BaseLayout
  title="India ESG, GHG and OHSE Public Data Observatory"
  description="Step 1 public observatory foundation with transparent mock data and chart metadata."
>
  <main>
    <section class="article-hero article-hero--editorial">
      <p class="kicker">Public research observatory</p>
      <h1>India ESG, GHG and OHSE Public Data Observatory</h1>
      <p>
        This is a long-form public note, not a dashboard. Each graph is embedded as evidence
        inside a narrative on how to read climate, emissions, air, and social-risk signals
        together.
      </p>
      <p>
        Step 1 uses mock snapshots to establish method discipline: source traceability,
        timeframe context, and visible caveats before interpretation.
      </p>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 1</p>
        <h2>Why public ESG, GHG, and OHSE data needs time context</h2>
      </div>
      <p class="chapter-copy">
        Public datasets rarely move at the same speed. Some signals update hourly, others are
        monthly, annual, or versioned releases. A responsible observatory has to make these
        different clocks visible so readers do not treat every line as real-time truth.
      </p>
      <p class="chapter-copy">
        This page therefore keeps metadata beside every chart and uses narrative structure
        between chart groups. The goal is readable public writing with scientific caution.
      </p>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 2</p>
        <h2>Emissions and grid context</h2>
      </div>
      <p class="chapter-copy">
        We begin with broad-scale emissions and electricity context, then place monthly movement
        in that frame. These charts are better for directional reading than instant conclusions.
      </p>
      <div class="cards cards--chapter">
        {
          chartSections.emissionsAndGrid.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 3</p>
        <h2>Air and climate context</h2>
      </div>
      <p class="chapter-copy">
        City-level air quality and weather can move faster than national emissions inventories.
        Reading these together helps separate immediate stress signals from longer-run changes.
      </p>
      <div class="cards cards--chapter">
        {
          chartSections.airAndClimate.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 4</p>
        <h2>Risk and social context</h2>
      </div>
      <p class="chapter-copy">
        Environmental exposure is only part of the public story. Water risk, workplace safety,
        and broad ESG/SDG indicators provide social context for interpreting climate-linked
        pressures.
      </p>
      <div class="cards cards--chapter">
        {
          chartSections.riskAndSocial.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 5</p>
        <h2>How to read this data</h2>
      </div>
      <ol class="reading-list">
        {howToReadPoints.map((point) => <li>{point}</li>)}
      </ol>
      <p class="mock-note">
        Mock data is intentionally used throughout this page. Live connector integration and
        source validation are separate phases.
      </p>
    </section>

    <section class="chapter chapter--appendix">
      <div class="chapter-head">
        <p class="kicker">Appendix</p>
        <h2>Data freshness table</h2>
      </div>
      <p class="chapter-copy">
        This appendix lists retrieval timestamps and status flags across all current mock
        datasets so readers can audit update rhythm at a glance.
      </p>
      <DataFreshnessTable client:load endpoint="/api/data-freshness.json" />
    </section>
  </main>
</BaseLayout>
