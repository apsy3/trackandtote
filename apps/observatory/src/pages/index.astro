---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialNotesIndex from "@/components/home/EditorialNotesIndex.astro";
import FeaturedProject from "@/components/home/FeaturedProject.astro";
import HeroSplit from "@/components/home/HeroSplit.astro";
import MethodManifesto from "@/components/home/MethodManifesto.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const methodItems = [
  {
    title: "Source-aware",
    detail: "Trace the source before trusting the signal.",
  },
  {
    title: "Time-aware",
    detail: "Keep observation and retrieval dates visible.",
  },
  {
    title: "Mock-first",
    detail: "Prototype structure before connecting live data.",
  },
  {
    title: "Careful claims",
    detail: "Do not describe data as complete or live without support.",
  },
] as const;
---

<BaseLayout
  title="Track & Tote"
  description="Public writing and early data experiments around society, sustainability, reporting and decision-making."
>
  <main class="home-page">
    <HeroSplit />
    <FeaturedProject />
    <EditorialNotesIndex notes={notes} />
    <MethodManifesto items={methodItems} />
  </main>
</BaseLayout>
