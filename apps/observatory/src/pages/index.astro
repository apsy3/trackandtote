---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const methodItems = [
  {
    title: "Source-aware",
    detail: "Trace the source before trusting the signal.",
  },
  {
    title: "Time-aware",
    detail: "Keep observation and retrieval dates visible.",
  },
  {
    title: "Mock-first",
    detail: "Prototype structure before connecting live data.",
  },
  {
    title: "Careful claims",
    detail: "Do not describe data as complete or live without support.",
  },
] as const;
---

<BaseLayout
  title="Track & Tote"
  description="Careful writing and early data experiments around society, sustainability, reporting and decision-making."
>
  <main>
    <section class="home-hero">
      <img
        src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1800&q=80"
        alt="Printed reports, notebooks, and research material arranged for review"
        loading="eager"
      />
      <div class="home-hero-content">
        <p class="kicker">Public notes and data experiments</p>
        <h1>Track &amp; Tote</h1>
        <p class="home-hero-subtitle">
          Careful writing and early data experiments around society, sustainability, reporting and
          decision-making.
        </p>
      </div>
    </section>

    <section class="editorial-statement" aria-label="Editorial statement">
      <p>
        Track &amp; Tote is a working space for essays, method notes and small public-data
        prototypes. Some projects are exploratory; some are practical. The common thread is
        disciplined evidence and careful language.
      </p>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Featured project</p>
        <h2>India ESG/OHSE Public Data Project</h2>
      </div>
      <article class="feature-card">
        <p class="status-label">Mock-data prototype</p>
        <p>
          An early-stage project exploring how public datasets can support sustainability, safety
          and reporting context over time.
        </p>
        <a class="button" href="/projects/india-esg-ohse">View project</a>
      </article>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Notes</p>
        <h2>Recent writing</h2>
        <p class="section-copy">
          Essays and working notes across society, public data, sustainability, technology,
          reporting and decision-making.
        </p>
      </div>
      <div class="notes-grid">
        {
          notes.map((note) => (
            <article class="note-card">
              <h3>
                <a href={`/notes/${note.slug}/`}>{note.data.title}</a>
              </h3>
              <p>{note.data.description}</p>
              <div class="note-meta">
                <time datetime={note.data.date.toISOString()}>
                  {note.data.date.toLocaleDateString("en-IN", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit",
                  })}
                </time>
              </div>
            </article>
          ))
        }
      </div>
      <p class="subtle-link">
        <a href="/notes">Browse all notes</a>
      </p>
    </section>

    <section class="section-block">
      <div class="section-head">
        <p class="kicker">Method strip</p>
        <h2>How we keep the work disciplined</h2>
      </div>
      <div class="method-strip">
        {
          methodItems.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
