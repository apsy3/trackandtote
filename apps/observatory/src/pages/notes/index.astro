---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotesArchiveList from "@/components/notes/NotesArchiveList.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const categories = ["All", "Society", "Public data", "Method", "Sustainability"] as const;
---

<BaseLayout
  title="Notes | Track & Tote"
  description="Essays and working notes across society, public data, sustainability, technology, reporting and decision-making."
>
  <main>
    <section class="archive-hero">
      <p class="kicker">Notes</p>
      <h1>Notes for reading systems slowly.</h1>
      <p>
        Essays and working notes across society, public data, sustainability, technology, reporting
        and decision-making.
      </p>
      <div class="filter-chips" aria-label="Visual note categories">
        {categories.map((category) => <span>{category}</span>)}
      </div>
    </section>

    <NotesArchiveList notes={notes} />
  </main>
</BaseLayout>
