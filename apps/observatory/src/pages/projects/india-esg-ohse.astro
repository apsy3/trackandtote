---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ChartSectionCard from "@/components/charts/ChartSectionCard";
import DataFreshnessTable from "@/components/charts/DataFreshnessTable";
import { indiaProjectChartSections } from "@/lib/projectContent";

const readingPoints = [
  "Read frequency first. Annual and versioned datasets cannot answer daily questions.",
  "Interpret across clocks. Air quality, rainfall, emissions, and OHSE series move at different speeds.",
  "Use confidence and status labels to calibrate claims and avoid overstatement.",
  "Treat this as an evolving public notebook while source licensing and governance move toward connector-by-connector validation.",
] as const;
---

<BaseLayout
  title="India ESG/OHSE Public Data Project | Track & Tote"
  description="An open, evolving experiment to connect public ESG, GHG, OHSE and sustainability datasets over time."
>
  <main>
    <section class="article-hero article-hero--project">
      <p class="kicker">Project</p>
      <h1>India ESG/OHSE Public Data Project</h1>
      <p>
        An open, evolving experiment to connect public ESG, GHG, OHSE and sustainability datasets
        over time.
      </p>
      <p class="project-status">
        This page currently uses mock data. Real public datasets will be connected source by source
        after licence, attribution, caching and refresh rules are verified.
      </p>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 1</p>
        <h2>Emissions and grid context</h2>
      </div>
      <p class="chapter-copy">
        Start with national emissions and power context before reading shorter-term movement.
        These charts provide structure for interpretation, not instant conclusions.
      </p>
      <div class="cards cards--chapter">
        {
          indiaProjectChartSections.emissionsAndGrid.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 2</p>
        <h2>Air and climate context</h2>
      </div>
      <p class="chapter-copy">
        Air quality and weather are typically faster-moving signals. They can indicate stress
        periods but still need timeframe discipline before cross-claiming.
      </p>
      <div class="cards cards--chapter">
        {
          indiaProjectChartSections.airAndClimate.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 3</p>
        <h2>Risk and social context</h2>
      </div>
      <p class="chapter-copy">
        Sustainability interpretation improves when environmental and social indicators are read in
        the same frame, with clear caveats on what is still uncertain.
      </p>
      <div class="cards cards--chapter">
        {
          indiaProjectChartSections.riskAndSocial.map((section) => (
            <ChartSectionCard
              client:load
              title={section.title}
              endpoint={section.endpoint}
              variant={section.variant}
            />
          ))
        }
      </div>
    </section>

    <section class="chapter">
      <div class="chapter-head">
        <p class="kicker">Section 4</p>
        <h2>How to read this project</h2>
      </div>
      <ol class="reading-list">
        {readingPoints.map((point) => <li>{point}</li>)}
      </ol>
    </section>

    <section class="chapter chapter--appendix">
      <div class="chapter-head">
        <p class="kicker">Appendix</p>
        <h2>Data freshness table</h2>
      </div>
      <p class="chapter-copy">
        Retrieval timestamps and status flags are listed here as a compact audit surface for all
        current mock datasets.
      </p>
      <DataFreshnessTable client:load endpoint="/api/data-freshness.json" />
    </section>
  </main>
</BaseLayout>
