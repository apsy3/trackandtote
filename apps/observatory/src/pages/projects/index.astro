---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Projects | Track & Tote" description="Public data projects and experiments.">
  <main>
    <section class="article-hero">
      <p class="kicker">Projects</p>
      <h1>Ongoing public-data experiments</h1>
      <p>
        Each project starts with clear scope, transparent metadata, and mock-first validation
        before live connectors are introduced.
      </p>
    </section>

    <section class="projects-grid">
      <article class="feature-card">
        <h2>India ESG/OHSE Public Data Project</h2>
        <p>
          An open, evolving experiment to connect public ESG, GHG, OHSE and sustainability
          datasets over time.
        </p>
        <a class="button" href="/projects/india-esg-ohse">View project</a>
      </article>
    </section>
  </main>
</BaseLayout>
