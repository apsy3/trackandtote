---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-nav">
        <a class="brand" href="/">Track &amp; Tote</a>
        <nav class="nav-links" aria-label="Primary navigation">
          <span class="nav-explore" aria-hidden="true">Explore</span>
          <a class:list={["nav-link", path === "/" && "is-active"]} href="/">Home</a>
          <a class:list={["nav-link", path.startsWith("/notes") && "is-active"]} href="/notes">
            Notes
          </a>
          <div class="nav-item nav-item--projects">
            <a
              class:list={["nav-link", path.startsWith("/projects") && "is-active"]}
              href="/projects"
              aria-describedby="projects-preview"
            >
              Projects
            </a>
            <div class="nav-popover" id="projects-preview">
              <p class="nav-popover__label">Current work</p>
              <a href="/projects/india-esg-ohse">
                <strong>India ESG/OHSE Public Data Project</strong>
                <span>Mock-data prototype, source governance first.</span>
              </a>
            </div>
          </div>
          <a class:list={["nav-link", path.startsWith("/method") && "is-active"]} href="/method">
            Method
          </a>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <p>Track &amp; Tote</p>
        <p>Public notes and early data experiments.</p>
      </footer>
    </div>
  </body>
</html>
