---
const heroImage =
  "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1600&q=82";
---

<section class="hero-split" aria-labelledby="home-hero-title">
  <div class="hero-split__copy">
    <p class="kicker">PUBLIC NOTES AND DATA EXPERIMENTS</p>
    <h1 id="home-hero-title">Careful notes for complex systems.</h1>
    <p class="hero-split__subtitle">
      Writing, methods and early data experiments across society, sustainability, reporting and
      decision-making.
    </p>
    <p class="hero-split__statement">
      A working space for essays, method notes and public-data prototypes &mdash; built slowly,
      with source discipline and careful language.
    </p>
    <div class="hero-actions">
      <a class="button button--primary" href="/notes">Read notes</a>
      <a class="button button--quiet" href="/projects">View projects</a>
    </div>
  </div>

  <div class="hero-split__stage">
    <figure class="hero-split__visual">
      <img
        src={heroImage}
        alt="Printed reports, notebooks, and research material arranged for review"
        loading="eager"
        decoding="async"
      />
      <figcaption>Notes / sources / prototypes</figcaption>
    </figure>
    <span class="hero-data-mark hero-data-mark--one">source</span>
    <span class="hero-data-mark hero-data-mark--two">method</span>
    <span class="hero-data-mark hero-data-mark--three">time</span>
  </div>
</section>
