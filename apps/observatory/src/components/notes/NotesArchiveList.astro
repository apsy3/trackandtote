---
import type { CollectionEntry } from "astro:content";

interface Props {
  notes: CollectionEntry<"blog">[];
  compact?: boolean;
}

const { notes, compact = false } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-IN", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
---

<div class:list={["archive-list", compact && "archive-list--compact"]}>
  {
    notes.map((note, index) => (
      <article class="archive-row">
        <a class="archive-row__link" href={`/notes/${note.slug}/`}>
          <span class="archive-row__count">{String(index + 1).padStart(2, "0")}</span>
          <span class="archive-row__visual" aria-hidden="true">
            <span>{note.data.tags[0] ?? "note"}</span>
          </span>
          <span class="archive-row__body">
            <span class="archive-row__meta">
              <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
              <span>{note.data.tags.slice(0, 3).join(" / ")}</span>
            </span>
            <h2>{note.data.title}</h2>
            <span class="archive-row__summary">{note.data.description}</span>
          </span>
          <span class="archive-row__arrow" aria-hidden="true">Read</span>
        </a>
      </article>
    ))
  }
</div>
